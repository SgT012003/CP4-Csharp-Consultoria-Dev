# Copie este arquivo para .env e preencha os valores reais
# NUNCA comite o arquivo .env no controle de versão

# ── SQL Server ──────────────────────────────────────────────────────────────
# Senha do SA — deve ter: min 8 chars, maiusculas, numeros, especiais
SA_PASSWORD=YourStrong!Passw0rd#2026

# ── Chaves de Acesso ────────────────────────────────────────────────────────
MASTER_ACCESS_KEY=change-me-to-a-secure-random-key

# ── Integrações Externas ────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
# ── deixe vazio para usar atravez do link ───────────────────────────────────